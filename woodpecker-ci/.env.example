# Woodpecker CI
WOODPECKER_DOMAIN=ci.yourdomain.com

# Gitea OAuth integration
GITEA_URL=https://git.yourdomain.com
GITEA_CLIENT_ID=change_me_client_id
GITEA_CLIENT_SECRET=change_me_client_secret

# Shared secret between server and agent (generate: openssl rand -hex 32)
WOODPECKER_AGENT_SECRET=change_me_agent_secret
WOODPECKER_ADMIN=yourusername

# Database
POSTGRES_USER=woodpecker
POSTGRES_PASSWORD=ChangeMeNow!
