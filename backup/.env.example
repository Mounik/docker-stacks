# Backup schedule (cron expression)
BACKUP_CRON=0 2 * * *

# Backup file prefix
BACKUP_PREFIX=homelab-backup

# Retention in days
BACKUP_RETENTION_DAYS=7

# S3-compatible storage (optional, local archive if empty)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=
# S3_ENDPOINT=https://s3.example.com